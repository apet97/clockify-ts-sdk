{
    "extends": "./tsconfig.json",
    "compilerOptions": {
        "noEmit": false,
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true,
        "outDir": "./dist/cjs",
        "rootDir": ".",
        "module": "CommonJS",
        "moduleResolution": "Node",
        "verbatimModuleSyntax": false
    },
    "include": [
        "src/**/*.ts",
        "index.ts",
        "create-client.ts",
        "composed-fetch.ts",
        "iter.ts",
        "pagination.ts",
        "webhooks.ts",
        "webhook-events.ts",
        "with-response.ts",
        "scoped-client.ts",
        "otel-hooks.ts",
        "health.ts",
        "rate-limit.ts"
    ],
    "exclude": ["node_modules", "dist", "tests"]
}
