{
    "$schema": "../node_modules/@stryker-mutator/core/schema/stryker-schema.json",
    "packageManager": "npm",
    "testRunner": "vitest",
    "vitest": {
        "configFile": "wrapper/vitest.config.ts",
        "dir": "wrapper",
        "related": true
    },
    "coverageAnalysis": "all",
    "mutate": [
        "wrapper/money.ts",
        "wrapper/dates.ts",
        "wrapper/errors.ts",
        "wrapper/iter.ts",
        "wrapper/composed-fetch.ts",
        "wrapper/webhook-url.ts",
        "!wrapper/src/**",
        "!wrapper/webhook-events.ts",
        "!wrapper/*.config.*",
        "!wrapper/tests/**",
        "!wrapper/scripts/**",
        "!wrapper/dist/**"
    ],
    "reporters": ["json", "clear-text"],
    "jsonReporter": {
        "fileName": "wrapper/reports/mutation/mutation.json"
    },
    "timeoutMS": 60000,
    "concurrency": 2,
    "tempDirName": "wrapper/.stryker-tmp"
}
