{
    "name": "clockify-sdk-ts",
    "version": "0.5.0",
    "description": "TypeScript SDK for the Clockify API — generated from the canonical OpenAPI by Fern, wrapped with a publishable package layout.",
    "license": "MIT",
    "author": "Aleksandar Petković <petkovic.aleksandar037@gmail.com>",
    "homepage": "https://github.com/apet97/clockify-ts-sdk",
    "repository": {
        "type": "git",
        "url": "https://github.com/apet97/clockify-ts-sdk.git"
    },
    "bugs": {
        "url": "https://github.com/apet97/clockify-ts-sdk/issues"
    },
    "keywords": [
        "clockify",
        "sdk",
        "typescript",
        "api-client",
        "time-tracking",
        "fern",
        "openapi"
    ],
    "type": "module",
    "main": "./dist/cjs/index.js",
    "module": "./dist/esm/index.js",
    "types": "./dist/esm/index.d.ts",
    "sideEffects": false,
    "exports": {
        ".": {
            "import": {
                "types": "./dist/esm/index.d.ts",
                "default": "./dist/esm/index.js"
            },
            "require": {
                "types": "./dist/cjs/index.d.ts",
                "default": "./dist/cjs/index.js"
            }
        },
        "./create-client": {
            "import": {
                "types": "./dist/esm/create-client.d.ts",
                "default": "./dist/esm/create-client.js"
            },
            "require": {
                "types": "./dist/cjs/create-client.d.ts",
                "default": "./dist/cjs/create-client.js"
            }
        },
        "./composed-fetch": {
            "import": {
                "types": "./dist/esm/composed-fetch.d.ts",
                "default": "./dist/esm/composed-fetch.js"
            },
            "require": {
                "types": "./dist/cjs/composed-fetch.d.ts",
                "default": "./dist/cjs/composed-fetch.js"
            }
        },
        "./iter": {
            "import": {
                "types": "./dist/esm/iter.d.ts",
                "default": "./dist/esm/iter.js"
            },
            "require": {
                "types": "./dist/cjs/iter.d.ts",
                "default": "./dist/cjs/iter.js"
            }
        },
        "./webhooks": {
            "import": {
                "types": "./dist/esm/webhooks.d.ts",
                "default": "./dist/esm/webhooks.js"
            },
            "require": {
                "types": "./dist/cjs/webhooks.d.ts",
                "default": "./dist/cjs/webhooks.js"
            }
        },
        "./pagination": {
            "import": {
                "types": "./dist/esm/pagination.d.ts",
                "default": "./dist/esm/pagination.js"
            },
            "require": {
                "types": "./dist/cjs/pagination.d.ts",
                "default": "./dist/cjs/pagination.js"
            }
        },
        "./with-response": {
            "import": {
                "types": "./dist/esm/with-response.d.ts",
                "default": "./dist/esm/with-response.js"
            },
            "require": {
                "types": "./dist/cjs/with-response.d.ts",
                "default": "./dist/cjs/with-response.js"
            }
        },
        "./errors": {
            "import": {
                "types": "./dist/esm/errors.d.ts",
                "default": "./dist/esm/errors.js"
            },
            "require": {
                "types": "./dist/cjs/errors.d.ts",
                "default": "./dist/cjs/errors.js"
            }
        },
        "./deprecation": {
            "import": {
                "types": "./dist/esm/deprecation.d.ts",
                "default": "./dist/esm/deprecation.js"
            },
            "require": {
                "types": "./dist/cjs/deprecation.d.ts",
                "default": "./dist/cjs/deprecation.js"
            }
        }
    },
    "files": [
        "dist",
        "README.md",
        "LICENSE"
    ],
    "engines": {
        "node": ">=20"
    },
    "publishConfig": {
        "access": "public",
        "provenance": true
    },
    "scripts": {
        "sync": "bash scripts/sync-sdk.sh",
        "type-check": "tsc -p tsconfig.json --noEmit",
        "build": "tsc -p tsconfig.esm.json && tsc -p tsconfig.cjs.json && bash scripts/finalize-cjs.sh",
        "build:smoke": "bash scripts/verify-dual-build.sh",
        "docs": "typedoc",
        "docs:resources": "tsx scripts/gen-resource-docs.ts",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "clean": "rm -rf dist",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:types": "vitest --typecheck.only --run",
        "size": "size-limit",
        "prepublishOnly": "npm run sync && npm run type-check && npm run clean && npm run build && npm run build:smoke"
    },
    "devDependencies": {
        "@size-limit/file": "^12.1.0",
        "@types/node": "^22",
        "eslint": "^9.39.4",
        "eslint-plugin-import-x": "^4.16.2",
        "prettier": "^3.8.3",
        "size-limit": "^12.1.0",
        "tsx": "^4.22.3",
        "typedoc": "^0.28.19",
        "typescript": "^5.6.0",
        "typescript-eslint": "^8.59.4",
        "vitest": "^4.1.4"
    }
}
