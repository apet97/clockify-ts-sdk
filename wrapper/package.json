    "files": [
        "dist",
        "README.md",
        "LICENSE"
    ],
    "engines": {
        "node": ">=22.13.0"
    },
    "publishConfig": {
        "access": "public",
        "provenance": true
    },
    "scripts": {
        "sync": "bash scripts/sync-sdk.sh",
        "type-check": "node ../scripts/generate-package-versions.mjs && tsc -p tsconfig.json --noEmit",
        "build": "node ../scripts/generate-package-versions.mjs && npm run clean && tsc -p tsconfig.esm.json && tsc -p tsconfig.cjs.json && bash scripts/finalize-cjs.sh",
        "build:smoke": "bash scripts/verify-dual-build.sh",
        "docs": "node ../scripts/generate-package-versions.mjs && typedoc",
        "docs:resources": "tsx scripts/gen-resource-docs.ts",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "clean": "rm -rf dist",
        "test": "node ../scripts/generate-package-versions.mjs && vitest run",
        "test:coverage": "node ../scripts/generate-package-versions.mjs && vitest run --coverage",
        "mutation": "node ../scripts/generate-package-versions.mjs && cd .. && CLOCKIFY_API_KEY='' CLOCKIFY_WORKSPACE_ID='' stryker run wrapper/stryker.conf.json",
        "test:watch": "node ../scripts/generate-package-versions.mjs && vitest",
        "test:types": "node ../scripts/generate-package-versions.mjs && vitest --typecheck.only --run",
        "size": "size-limit",
        "prepublishOnly": "npm run sync && npm run type-check && npm test && npm run clean && npm run build && npm run build:smoke"
    },
    "overrides": {
        "typed-rest-client": {
            "qs": "6.15.3"
        }
    },
    "devDependencies": {
        "@size-limit/file": "^12.1.0",
        "@types/node": "^22",
        "@vitest/coverage-v8": "^4.1.10",
        "eslint": "^10.5.0",
        "eslint-plugin-import-x": "^4.17.1",
        "fast-check": "^4.9.0",
        "prettier": "^3.8.3",
        "size-limit": "^12.1.0",
        "tsx": "^4.22.3",
        "typedoc": "^0.28.19",
        "typescript": "^5.6.0",
        "typescript-eslint": "^8.64.0",
        "vitest": "^4.1.10"
    }
