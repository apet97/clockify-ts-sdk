{
  "schemaVersion": 1,
  "purpose": "Machine-readable map from change scope to required gates, docs, changelog posture, and receipts.",
  "wiring": {
    "makeTarget": "change-impact",
    "checker": "scripts/check-change-impact.mjs",
    "enterpriseAuditId": "change-impact"
  },
  "policyDocument": {
    "path": "docs/change-impact-policy.md",
    "contains": [
      "Start from the changed surface",
      "User-visible changes need documentation and changelog coverage",
      "Generated and snapshot surfaces remain upstream-first",
      "Proof can be deferred only when the final receipt says so",
      "operator helper tooling",
      "make operator-toolbox",
      "path-based triage cannot silently stop matching",
      "First-run support workflow changes route through diagnostics",
      "Duplicate scope ids, path probes, required targets, required docs, or changed-path entries are contract failures",
      "node scripts/change-impact-plan.mjs --scope <id>",
      "node scripts/change-impact-plan.mjs --path <changed-path>"
    ],
    "forbiddenMarkers": [
      "TODO",
      "TBD"
    ]
  },
  "planGenerator": {
    "path": "scripts/change-impact-plan.mjs",
    "makeTarget": "change-impact-plan",
    "contains": [
      "network: \"none\"",
      "commandsExecuted: []",
      "envValuesCaptured: false",
      "This plan is not proof",
      "Does not run Git, npm, Docker, Fern, tests, builds, or Clockify API calls",
      "docs/change-impact-contract.json",
      "--scope list",
      "--path <changed-path>"
    ],
    "generatedPlan": {
      "exactFields": {
        "schemaVersion": 1,
        "network": "none",
        "commandsExecuted": [],
        "envValuesCaptured": false,
        "reportScope": "default",
        "ok": true
      },
      "requiredMatchedScopeIds": [
        "docs-and-contracts",
        "axioms-contract",
        "release-readiness"
      ],
      "requiredScopeFields": [
        "changedPaths",
        "requiredTargets",
        "requiredDocs",
        "notes",
        "changelogRequired"
      ]
    }
  },
  "requiredScopeIds": [
