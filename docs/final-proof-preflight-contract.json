{
  "schemaVersion": 1,
  "purpose": "Contract for the no-network final-proof preflight target. This target must print orientation reports only and must not run proof gates, builds, tests, Git, Fern, Docker, npm, or Clockify API calls.",
  "wiring": {
    "makeTarget": "final-proof-preflight-contract",
    "checker": "scripts/check-final-proof-preflight-contract.mjs",
    "enterpriseAuditId": "final-proof-preflight-contract"
  },
  "makefile": {
    "path": "Makefile",
    "target": "final-proof-preflight",
    "contractTarget": "final-proof-preflight-contract",
    "requiredCommands": [
      "node scripts/enterprise-goal-status.mjs",
      "node scripts/release-readiness-report.mjs"
    ],
    "forbiddenInTarget": [
      "make perfect",
      "make enterprise-audit",
      "make final-proof-draft",
      "make final-proof-final",
      "make final-proof-receipt-check",
      "npm ",
      "git ",
      "fern ",
      "docker ",
      "CLOCKIFY_API_KEY",
      "CLOCKIFY_WORKSPACE_ID"
    ]
  },
  "docs": [
    {
      "path": "docs/final-proof-runbook.md",
      "mustContain": [
        "make final-proof-preflight",
        "This preflight prints the active-goal status report and release-readiness",
        "it is not proof",
        "Final blockers",
        "Blocking file-state summary",
        "finalBlockingSignalIds",
        "blockingSignalIds",
        "Live proof status: completed",
        "Live proof status: failed",
        "Residual risk status: none",
        "Draft receipts may use",
        "not final completion evidence"
      ]
    },
    {
      "path": "docs/release-readiness-checklist.md",
      "mustContain": [
        "make final-proof-preflight",
        "This preflight is static and no-network",
        "it is not release proof"
      ]
    },
    {
      "path": "docs/operator-toolbox.md",
      "mustContain": [
        "make final-proof-preflight",
        "without running proof gates"
      ]
    },
    {
      "path": "docs/quality-gates.md",
      "mustContain": [
        "Print final proof preflight",
        "Check final proof preflight contract",
        "make final-proof-preflight",
        "make final-proof-preflight-contract"
      ]
    },
    {
      "path": "docs/README.md",
      "mustContain": [
        "final-proof-preflight-contract.json",
        "Final proof preflight",
        "Final proof preflight contract"
      ]
    }
  ],
  "runner": {
    "path": "scripts/run-final-proof.mjs",
    "mustContain": [
      "runMake(\"final-proof-preflight\")",
      "title: \"No-network preflight\"",
      "commandBlock(\"make final-proof-preflight\")"
    ]
  },
  "supportingContracts": [
    {
      "path": "scripts/release-readiness-report.mjs",
      "mustContain": [
        "final-proof-preflight",
        "make final-proof-preflight",
        "requiredFinalProofCommandOrder",
        "enterprise-goal-status"
      ]
    },
    {
      "path": "docs/enterprise-goal-status-contract.json",
      "mustContain": [
        "finalProofCommandOrder",
        "requiredFinalProofCommandOrder",
        "make final-proof-preflight",
        "make perfect-live"
      ]
    },
    {
      "path": "docs/release-readiness-contract.json",
      "mustContain": [
        "make final-proof-preflight",
        "requiredFinalProofCommandOrder",
        "final-proof-preflight"
      ]
    },
    {
      "path": "docs/operator-toolbox-contract.json",
      "mustContain": [
        "make final-proof-preflight",
        "final-proof-preflight"
      ]
    }
  ],
  "generatedReports": [
    {
      "id": "enterprise-goal-status",
      "exactFields": {
        "schemaVersion": 1,
        "network": "none",
        "commandsExecuted": [],
        "envValuesCaptured": false,
        "reportScope": "enterprise-sdk-hardening-goal",
        "goalComplete": false
      },
      "requiredSignalIds": [
        "temporary-context",
        "final-proof-receipt",
        "final-proof-receipt-filled",
        "live-cleanup-proof",
        "live-proof-final-status",
        "performance-proof",
        "final-proof-failure-markers",
        "success-section-evidence",
        "residual-risk-final-status",
        "risk-register-final-status"
      ],
      "requiredBlockingFields": [
        "finalBlockingSignalIds",
        "finalBlockingRiskIds"
      ],
      "requiredOrderedArrays": {
        "finalProofCommandOrder": [
          "preflight",
          "enterpriseAudit",
          "axiomsContract",
          "perfectFast",
          "performanceReceipt",
          "perfectFull",
          "perfectLive",
          "draft",
          "receiptCheck",
          "final"
        ]
      }
    },
    {
      "id": "release-readiness-report",
      "exactFields": {
        "schemaVersion": 1,
        "network": "none",
        "commandsExecuted": [],
        "envValuesCaptured": false,
        "releaseReady": false,
        "reportScope": "preflight-only"
      },
      "requiredSignalIds": [
        "temporary-context",
        "final-proof-receipt",
        "final-proof-receipt-filled",
        "live-cleanup-proof",
        "live-proof-final-status",
        "performance-proof",
        "final-proof-failure-markers",
        "success-section-evidence",
        "residual-risk-final-status",
        "risk-register-final-status"
      ],
      "requiredBlockingFields": [
        "blockingSignalIds",
        "blockingRiskIds"
      ],
      "requiredOrderedArrays": {
        "requiredFinalProofCommandOrder": [
          "final-proof-preflight",
          "enterprise-audit",
          "axioms-contract",
          "perfect-fast",
          "performance-receipt",
          "perfect-full",
          "perfect-live",
          "final-proof-draft",
          "final-proof-receipt-check",
          "final-proof-final"
        ]
      }
    }
  ],
  "contractInvariants": [
    "valid-schema-version",
    "valid-purpose",
    "safe-final-proof-preflight-paths",
    "typed-makefile-contract",
    "typed-doc-marker-contracts",
    "typed-generated-report-contracts",
    "typed-runner-and-support-contracts",
    "makefile-audit-wiring"
  ]
}
