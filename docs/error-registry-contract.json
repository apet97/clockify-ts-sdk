{
  "schemaVersion": 1,
  "purpose": "Integrity anchor for the shared error-code registry. Pins the code count and id set, required per-code fields, mirrored package copies, and the reachable subset grounded by HTTP-status mapping, classifier code, or tests. Catches semantic regressions that error-docs-drift cannot catch after regenerating from a smaller or renamed source registry.",
  "registry": "docs/error-codes.json",
  "expectedCodeCount": 16,
  "expectedCodeIds": [
    "invalid_request",
    "auth_or_permission",
    "feature_unavailable",
    "not_found",
    "conflict",
    "rate_limited",
    "clockify_upstream_error",
    "connection_error",
    "aborted",
    "rate_limited_retry_after",
    "addon_token_restricted",
    "host_routing_required",
    "active_resource_delete_blocked",
    "dead_route",
    "name_reserved_after_delete",
    "error"
  ],
  "requiredFields": [
    "code",
    "httpStatus",
    "retry",
    "surfaces",
    "meaning",
    "recovery",
    "reachable"
  ],
  "packageCopies": [
    "wrapper/error-codes.ts",
    "cli/src/error-codes.ts",
    "mcp/src/error-codes.ts"
  ],
  "reachableCodes": [
    "invalid_request",
    "auth_or_permission",
    "feature_unavailable",
    "not_found",
    "conflict",
    "rate_limited",
    "clockify_upstream_error",
    "connection_error",
    "aborted",
    "rate_limited_retry_after",
    "addon_token_restricted",
    "active_resource_delete_blocked",
    "error"
  ],
  "reachabilitySources": [
    "wrapper/error-codes.ts",
    "wrapper/errors.ts",
    "wrapper/tests/error-code-wiring.test.ts",
    "wrapper/tests/errors.test.ts"
  ],
  "wiring": {
    "makeTarget": "error-registry",
    "checker": "scripts/check-error-registry.mjs",
    "qualityGate": "make error-registry",
    "inventoryId": "error-registry",
    "auditId": "error-registry"
  }
}
