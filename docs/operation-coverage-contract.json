{
  "schemaVersion": 1,
  "purpose": "No-regression operation coverage baseline across corrected OpenAPI operations, SDK method stamps, TS MCP exact tool matches, GOCLMCP exact tool matches, and curated parity overrides.",
  "policyDocument": {
    "path": "docs/operation-coverage-policy.md",
    "contains": [
      "Coverage baseline",
      "OpenAPI operations",
      "Generated SDK operations",
      "Explicitly named SDK operations",
      "OperationId-derived SDK operations",
      "TS MCP exact operation/tool matches",
      "GOCLMCP exact operation/tool matches",
      "Curated parity overrides",
      "Required escalation",
      "make operation-coverage"
    ],
    "forbiddenMarkers": [
      "TODO",
      "TBD"
    ]
  },
  "reportInputs": {
    "openapiOperations": "docs/openapi-operations.json",
    "operationParity": "docs/operation-parity.json",
    "operationDispositions": "docs/operation-dispositions.json",
    "sdkNamingClassifications": "docs/sdk-operation-naming-classifications.json",
    "operationEvidence": "docs/operation-evidence-map.json",
    "discrepancyLedger": "spec/evidence/discrepancies.md",
    "sdkCodegenReceipt": "output/ts-sdk/codegen-receipt.json"
  },
  "generatedInputWiring": {
    "coveragePrerequisites": ["operation-parity-drift"],
    "coverageRecipes": [
      "node --test scripts/generate-operation-parity.test.mjs",
      "node scripts/check-operation-coverage.mjs"
    ],
    "sdkBuildTarget": "sdk-wrapper-build",
    "sdkBuildPrerequisites": ["sdk-codegen-sync"],
    "codegenTarget": "sdk-codegen-sync",
    "codegenRecipes": [
      "node scripts/generate-sdk-from-openapi.mjs --write",
      "cd wrapper && npm run sync"
    ]
  },
  "driftWiring": {
    "target": "operation-parity-drift",
    "requiredPrerequisites": [
      "mcp-tool-manifest-drift"
    ],
    "forbiddenPrerequisites": [
      "mcp-tool-manifest"
    ]
  },
  "manifestProofWiring": {
    "driftTarget": "mcp-tool-manifest-drift",
    "driftPrerequisites": [
      "sdk-wrapper-build"
    ],
    "driftRecipes": [
      "cd mcp && node --import tsx scripts/generate-tool-manifest.mjs --check"
    ],
    "writerTarget": "mcp-tool-manifest",
    "writerPrerequisites": [
      "sdk-wrapper-build"
    ],
    "writerRecipes": [
      "cd mcp && node --import tsx scripts/generate-tool-manifest.mjs --write"
    ]
  },
  "thresholds": {
    "operations": 169,
    "sdkGenerated": 169,
    "sdkExplicitlyNamed": 155,
    "sdkOperationIdDerived": 14,
    "tsMcpExact": 92,
    "goMcpExact": 82,
    "curated": 32
  },
  "requiredTargets": [
    "operation-coverage",
    "openapi-lint",
    "operation-parity-drift",
    "generator-comparison",
    "naming-taxonomy"
  ],
  "requiredDocs": [
    "docs/operation-coverage-policy.md",
    "docs/openapi-operations.json",
    "docs/operation-dispositions.json",
    "docs/operation-evidence-map.json",
    "docs/operation-parity.json",
    "docs/operation-parity-overrides.json",
    "docs/sdk-operation-naming-classifications.json",
    "docs/naming-taxonomy-policy.md",
    "docs/risk-register.md"
  ],
  "supportingEvidence": [
    {
      "path": "docs/openapi-operations.json",
      "contains": [
        "operationId",
        "sdkGroup",
        "sdkMethod"
      ]
    },
    {
      "path": "docs/operation-dispositions.json",
      "contains": [
        "sdkGenerated",
        "sdkExplicitlyNamed",
        "sdkOperationIdDerived",
        "reachable",
        "evidenceIds"
      ]
    },
    {
      "path": "docs/operation-evidence-map.json",
      "contains": [
        "Governed discrepancy-ledger evidence",
        "createRecurringAssignment",
        "updateInvoice",
        "evidenceIds"
      ]
    },
    {
      "path": "docs/operation-parity.json",
      "contains": [
        "sdkGenerated",
        "sdkExplicitlyNamed",
        "sdkOperationIdDerived",
        "tsMcpExact",
        "goMcpExact",
        "curated",
        "candidateTools"
      ]
    },
    {
      "path": "docs/sdk-operation-naming-classifications.json",
      "contains": [
        "operationId-derived",
        "generatedGroup",
        "generatedMethod"
      ]
    },
    {
      "path": "docs/operation-parity-overrides.json",
      "contains": [
        "Curated TS MCP and GOCLMCP parity mappings",
        "reason"
      ]
    },
    {
      "path": "scripts/generate-operation-parity.mjs",
      "contains": [
        "codegen-receipt.json",
        "tsMcpExact",
        "goMcpExact",
        "curated"
      ]
    },
    {
      "path": "scripts/lib/operation-parity-contract.mjs",
      "contains": [
        "sdkGenerated",
        "sdkExplicitlyNamed",
        "sdkOperationIdDerived",
        "unclassified operationId-derived generated operation",
        "duplicate ${label} rows"
      ]
    },
    {
      "path": "scripts/lint-openapi-contract.mjs",
      "contains": [
        "expected exactly 155 explicitly named SDK operations",
        "expected 169 operations"
      ]
    }
  ],
  "wiring": {
    "makeTarget": "operation-coverage",
    "checker": "scripts/check-operation-coverage.mjs",
    "docsIndex": [
      "operation-coverage-policy.md",
      "operation-coverage-contract.json"
    ],
    "qualityGate": "make operation-coverage",
    "inventoryId": "operation-coverage",
    "auditId": "operation-coverage"
  }
}
