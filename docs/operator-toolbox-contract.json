    "requiredOwnedScripts": [
      "scripts/repo-doctor.mjs",
      "scripts/onboarding-plan.mjs",
      "scripts/enterprise-goal-status.mjs",
      "scripts/workflow-plan.mjs",
      "scripts/acceptance-plan.mjs",
