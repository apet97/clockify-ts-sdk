  "helperCommandCoverageInvariants": [
    "no-extra-script-mappings",
    "no-duplicate-script-mappings"
  ],
  "helperOwnership": {
    "inventoryPath": "docs/contract-inventory.json",
    "ownedBy": [
      "reportGenerator.path",
