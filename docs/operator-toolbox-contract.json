        "toolbox helper ownership"
      ]
    },
    {
      "path": "docs/README.md",
      "mustContain": [
        "inventory-ownership contract",
        "inventory ownership for operators"
      ]
    }
  ],
  "contractInvariants": [
    "valid-schema-version",
    "valid-purpose",
    "safe-toolbox-paths",
    "typed-helper-lists",
    "typed-helper-command-coverage",
    "typed-helper-ownership-contract",
