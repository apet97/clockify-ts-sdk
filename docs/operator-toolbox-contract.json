{
  "schemaVersion": 1,
  "purpose": "Operator toolbox contract for no-network preflight helpers that orient non-coders and future agents without claiming proof.",
  "wiring": {
    "makeTarget": "operator-toolbox",
    "checker": "scripts/check-operator-toolbox.mjs",
    "enterpriseAuditId": "operator-toolbox"
  },
  "toolbox": {
    "path": "docs/operator-toolbox.md",
    "mustContain": [
      "Operator Toolbox",
      "No command in this toolbox runs Git, npm, Docker, Fern, tests, builds, or Clockify API calls",
      "node scripts/repo-doctor.mjs",
      "node scripts/onboarding-plan.mjs --goal all",
      "Shape-checked Markdown or JSON onboarding plan",
      "node scripts/enterprise-goal-status.mjs",
      "node scripts/enterprise-goal-status.mjs --format json",
      "make enterprise-goal-status",
      "make final-proof-preflight",
      "make enterprise-audit",
      "make perfect-fast",
      "make performance-receipt",
      "make perfect-full",
      "make perfect-live",
      "final-proof evidence sequence",
      "final-proof-draft",
      "final-proof-receipt-check",
      "node scripts/workflow-plan.mjs --workflow first-run-support",
      "Shape-checked no-network SDK, CLI, MCP diagnostics path",
      "safeCommandHints",
      "node scripts/workflow-plan.mjs --workflow all",
      "Shape-checked SDK, CLI, MCP paths",
      "node scripts/acceptance-plan.mjs --scenario all",
      "Shape-checked scenario proof plan",
      "node scripts/examples-plan.mjs --example all",
      "Shape-checked SDK, CLI, MCP examples",
      "node scripts/change-impact-plan.mjs --path docs/workflow-cookbook.md",
      "Shape-checked change scopes",
      "node scripts/maintenance-plan.mjs --cadence all",
      "Shape-checked weekly, monthly, dependency, generator, drift, release, and rollback plans",
      "node scripts/contract-inventory-report.mjs",
      "generated report/helper ownership",
      "Every helper in this toolbox has an owner in `docs/contract-inventory.json`",
      "node scripts/risk-status-report.mjs --status all",
      "generated risk-status report shape",
      "node scripts/release-readiness-report.mjs",
      "node scripts/release-decision-plan.mjs --decision all",
      "generated approval-boundary checks",
      "node scripts/performance-calibration-plan.mjs",
      "Budget-policy-backed calibration path",
      "node scripts/create-support-bundle.mjs --output /tmp/clockify-support-bundle.json",
      "make axioms-contract",
      "make final-proof-final",
      "Inventory shape status",
      "structural invariants",
      "safe repo-relative paths",
      "finalBlockingSignalIds",
      "finalBlockingRiskIds",
      "blockingSignalIds",
      "blockingRiskIds"
    ],
    "forbiddenMarkers": [
      "TODO",
      "TBD"
    ]
  },
  "helperScripts": [
    "scripts/repo-doctor.mjs",
    "scripts/onboarding-plan.mjs",
    "scripts/enterprise-goal-status.mjs",
    "scripts/workflow-plan.mjs",
    "scripts/acceptance-plan.mjs",
    "scripts/examples-plan.mjs",
    "scripts/change-impact-plan.mjs",
    "scripts/maintenance-plan.mjs",
    "scripts/contract-inventory-report.mjs",
    "scripts/risk-status-report.mjs",
    "scripts/release-readiness-report.mjs",
    "scripts/release-decision-plan.mjs",
    "scripts/performance-calibration-plan.mjs",
    "scripts/create-support-bundle.mjs"
  ],
  "listInvariants": [
    "typed-helper-command-coverage",
    "typed-helper-lists",
    "safe-toolbox-paths",
    "valid-purpose",
    "valid-schema-version",
    "unique-helper-scripts",
    "unique-required-owned-scripts",
    "unique-required-targets",
    "unique-supporting-docs",
    "makefile-audit-wiring"
