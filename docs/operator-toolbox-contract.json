      "script": "scripts/performance-calibration-plan.mjs",
      "documentedCommand": "node scripts/performance-calibration-plan.mjs"
    },
    {
      "script": "scripts/create-support-bundle.mjs",
      "documentedCommand": "node scripts/create-support-bundle.mjs --output /tmp/clockify-support-bundle.json"
    }
