{
  "schemaVersion": 1,
  "purpose": "Official-vs-custom OpenAPI drift pipeline contract: the committed official snapshot is compared against the corrected spec and the live-evidence ledger, and three trust surfaces are generated and kept fresh.",
  "policyDocument": {
    "path": "docs/official-openapi-drift-policy.md",
    "mustContain": [
      "Official OpenAPI drift",
      "make official-openapi-drift",
      "make official-openapi-report",
      "NEW_OFFICIAL_ENDPOINT",
      "CUSTOM_BETTER",
      "CONFLICT",
      "PHANTOM_RISK",
      "spec/evidence/discrepancies.md"
    ],
    "forbiddenMarkers": ["TODO", "TBD"]
  },
  "generatedBanner": "Generated by scripts/official-openapi-drift.mjs",
  "generatedTruthSurfaces": [
    "docs/spec-diff-official.md",
    "docs/spec-confidence.md",
    "docs/live-evidence-index.md"
  ],
  "reportLibrary": "scripts/official-openapi-report.mjs",
  "driver": "scripts/official-openapi-drift.mjs",
  "requiredMakeTargets": ["official-openapi-drift", "official-openapi-report"],
  "wiring": {
    "makeTarget": "official-openapi-drift",
    "reportTarget": "official-openapi-report",
    "checker": "scripts/check-official-openapi-drift.mjs",
    "qualityGate": "make official-openapi-drift",
    "inventoryId": "official-openapi-drift",
    "auditId": "official-openapi-drift",
    "docsIndex": [
      "official-openapi-drift-policy.md",
      "official-openapi-drift-contract.json"
    ]
  }
}
