{
  "schemaVersion": 1,
  "purpose": "Repo-owned local TypeScript generator configuration contract. Keeps the corrected OpenAPI input, generated output path, wrapper sync boundary, and offline command path intentional and reviewable.",
  "localGenerator": {
    "script": "scripts/generate-sdk-from-openapi.mjs",
    "writeCommand": "node scripts/generate-sdk-from-openapi.mjs --write",
    "checkCommand": "node scripts/generate-sdk-from-openapi.mjs --check",
    "testCommand": "npm run test:codegen",
    "inputOpenApi": "spec/corrected/clockify.corrected.openapi.yaml",
    "outputPath": "output/ts-sdk",
    "syncScript": "wrapper/scripts/sync-sdk.sh",
    "generatedWrapperPath": "wrapper/src"
  },
  "offlineReproducibility": {
    "requiresDocker": false,
    "requiresHostedLogin": false,
    "requiresApiToken": false,
    "forbiddenCommandMarkers": [
      "fern ",
      "docker ",
      "stainless",
      "speakeasy"
    ]
  },
  "fastRunner": {
    "path": "scripts/verify.mjs",
    "requiredMakeStepGroups": [
      [
        "sdk-codegen"
      ],
      [
        "sdk-codegen-drift",
        "sdk-codegen-test",
        "generated-edit-check"
      ]
    ]
  },
  "requiredDocs": [
    {
      "path": "docs/dependency-policy.md",
      "contains": [
        "Repo-owned local TypeScript generator",
        "scripts/generate-sdk-from-openapi.mjs",
        "make sdk-codegen"
      ]
    },
    {
      "path": "docs/generator-portability-plan.md",
      "contains": [
        "Repo-owned local generator chain",
        "scripts/generate-sdk-from-openapi.mjs",
        "output/ts-sdk"
      ]
    },
    {
      "path": "docs/decisions/0005-local-typescript-generator.md",
      "contains": [
        "repo-owned local TypeScript generator",
        "spec/corrected/clockify.corrected.openapi.yaml",
        "make sdk-codegen"
      ]
    }
  ],
  "wiring": {
    "makeTarget": "generator-config",
    "checker": "scripts/check-generator-config.mjs",
    "codegenTarget": "sdk-codegen",
    "codegenDriftTarget": "sdk-codegen-drift",
    "codegenTestTarget": "sdk-codegen-test",
    "docsIndex": [
      "generator-config-contract.json"
    ],
    "qualityGate": "make generator-config",
    "inventoryId": "generator-config",
    "auditId": "generator-config"
  }
}
