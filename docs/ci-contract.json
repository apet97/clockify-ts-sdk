{
  "schemaVersion": 1,
  "purpose": "CI/workflow posture contract. Checks workflow safety rails, package pack guards, and local documentation.",
  "policyDocument": {
    "path": "docs/ci-policy.md",
    "mustContain": [
      "Current workflow roles",
      "CI safety rules",
      "make ci-contract",
      "Legacy tag-triggered npm release path",
      "explicit maintainer approval"
    ],
    "forbiddenMarkers": [
      "TODO",
      "TBD"
    ]
  },
  "workflows": [
    {
      "path": ".github/workflows/ci.yml",
      "mustContain": [
        "name: CI",
        "node-version: [\"20\", \"22\"]",
        "npm run type-check",
        "npm run build",
        "npm run build:smoke",
        "npm test",
        "npm run test:types",
        "npm pack --dry-run --json",
        "npm run size",
        "make sdk-codegen",
        "make sdk-codegen-drift",
        "make openapi-lint",
        "make operation-parity-drift",
        "make openapi-operations-drift",
        "make product-surface-drift",
        "cross-gate:",
        "persist-credentials: false"
      ]
    },
    {
      "path": ".github/workflows/ci-cli.yml",
      "mustContain": [
        "name: CI (cli)",
        "node-version: [\"20\", \"22\"]",
        "make sdk-codegen",
        "npm run build -w clockify-sdk-ts-115",
        "working-directory: cli",
        "npm run type-check",
        "npm test",
        "npm run build",
        "node ../scripts/pack-snapshot.mjs --pkg=cli --check",
        "persist-credentials: false"
      ]
    },
    {
      "path": ".github/workflows/ci-mcp.yml",
      "mustContain": [
        "name: CI (mcp)",
        "node-version: [\"20\", \"22\"]",
        "make sdk-codegen",
        "npm run build -w clockify-sdk-ts-115",
        "working-directory: mcp",
        "npm run type-check",
        "npm test",
        "npm run build",
        "node ../scripts/pack-snapshot.mjs --pkg=mcp --check",
        "persist-credentials: false"
      ]
    },
    {
      "path": ".github/workflows/codeql.yml",
      "mustContain": [
        "name: CodeQL",
        "security-and-quality",
        "security-events: write",
        "- cli/src",
        "- mcp/src",
        "paths-ignore:",
        "- wrapper/src",
        ".github/workflows"
      ]
    },
    {
      "path": ".github/workflows/docs.yml",
      "mustContain": [
        "name: Docs",
        "pages: write",
        "id-token: write",
        "make sdk-codegen",
        "npm run docs",
        "actions/deploy-pages"
      ]
    },
    {
      "path": ".github/workflows/release-please.yml",
      "mustContain": [
        "name: release-please",
        "googleapis/release-please-action",
        "release-please-config.json",
        ".release-please-manifest.json"
      ]
    },
    {
      "path": ".github/workflows/release.yml",
      "mustContain": [
        "name: Release to npm",
        "tags:",
        "Verify tag matches package version",
        "id-token: write",
        "make sdk-codegen",
        "npm publish",
        "npm sbom",
        "Post-publish smoke install"
      ]
    },
    {
      "path": ".github/workflows/ci-cli-release.yml",
      "mustContain": [
        "Release @apet97/clockify-cli-115 to npm",
        "cli-v*.*.*",
        "workflow_dispatch",
        "working-directory: cli",
        "Verify tag matches package version",
        "github.ref_type == 'tag'",
        "npm publish",
        "persist-credentials: false"
      ]
    },
    {
      "path": ".github/workflows/ci-mcp-release.yml",
      "mustContain": [
        "Release @apet97/clockify-mcp-115 to npm",
        "mcp-v*.*.*",
        "workflow_dispatch",
        "working-directory: mcp",
        "Verify tag matches package version",
        "github.ref_type == 'tag'",
        "npm publish",
        "persist-credentials: false"
      ]
    },
    {
      "path": ".github/workflows/sandbox-key-health.yml",
      "mustContain": [
        "name: Sandbox key health",
        "schedule:",
        "cron: \"0 7 * * 1\"",
        "workflow_dispatch:",
        "permissions:",
        "contents: read",
        "persist-credentials: false",
        "secrets.CLOCKIFY_API_KEY",
        "secrets.CLOCKIFY_WORKSPACE_ID",
        "node scripts/check-sandbox-key-health.mjs"
      ]
    },
    {
      "path": ".github/workflows/mutation.yml",
      "mustContain": [
        "name: Mutation",
        "workflow_dispatch:",
        "target:",
        "type: choice",
        "make mutation",
        "npm run mutation -w clockify-sdk-ts-115",
        "npm run mutation -w @apet97/clockify-mcp-115",
        "node scripts/check-mutation-score.mjs --package wrapper",
        "node scripts/check-mutation-score.mjs --package mcp",
        "actions/upload-artifact@v4",
        "persist-credentials: false"
      ]
    }
  ],
  "supportingDocs": [
    {
      "path": "docs/release-support-policy.md",
      "mustContain": [
        "Do not change CI/CD",
        "npm publication is not the default path"
      ]
    },
    {
      "path": "scripts/release-decision-plan.mjs",
      "mustContain": [
        "network",
        "commandsExecuted",
        "explicitMaintainerApprovalRequired",
        "npm-via-ci"
      ]
    },
    {
      "path": "docs/risk-register.json",
      "mustContain": [
        "legacy-release-workflow-needs-maintainer-decision"
      ]
    },
    {
      "path": "AGENTS.md",
      "mustContain": [
        "Never run `npm publish`",
        ".github/workflows/**"
      ]
    }
  ],
  "wiring": {
    "makeTarget": "ci-contract",
    "checker": "scripts/check-ci-contract.mjs",
    "docsIndex": [
      "ci-policy.md",
      "ci-contract.json"
    ],
    "qualityGate": "make ci-contract",
    "inventoryId": "ci-contract",
    "auditId": "ci-contract"
  }
}
