{
  "schemaVersion": 2,
  "purpose": "Live sandbox test-data lifecycle contract for SDK, CLI, MCP, GOCLMCP, the exact-run prefix, governed legacy prefixes, dependency-ordered cleanup, and a zero-leftover final receipt.",
  "policyDocument": {
    "path": "docs/test-data-lifecycle-policy.md",
    "mustContain": [
      "Prefix ledger",
      "Lifecycle rules",
      "Dependency order",
      "Cleanup proof",
      "Stop conditions",
      "make test-data-lifecycle"
    ],
    "forbiddenMarkers": [
      "TODO",
      "TBD",
      "CLI live tests stay read-only"
    ]
  },
  "prefixes": [
    "clockify115-live-",
    "sdk-test-",
    "mcp-sandbox-",
    "mcp-workflow-",
    "mcp-log-",
    "mcp-fix-",
    "DEMO-"
  ],
  "entityOrder": [
    "time_entries",
    "scheduling_assignments",
    "time_off_requests",
    "expenses",
    "invoices",
    "shared_reports",
    "webhooks",
    "tasks",
    "projects",
    "clients",
    "tags"
  ],
  "orchestrator": {
    "path": "scripts/live/orchestrator.mjs",
    "mustContain": [
      "GOVERNED_LEGACY_PREFIXES",
      "clockify115-live-",
      "cleanupLivePrefixes",
      "rangeStart",
      "rangeEnd"
    ]
  },
  "cleanupLibrary": {
    "path": "scripts/live/cleanup.mjs",
    "mustContain": [
      "CLEANUP_ENTITY_ORDER",
      "validateCleanupOptions",
      "cleanupLivePrefixes",
      "sanitizedIdCount",
      "deletedCount",
      "failedCount",
      "remainingCount",
      "complete"
    ]
  },
  "liveTests": [
    {
      "path": "wrapper/tests/sandbox.test.ts",
      "mustContain": [
        "CLOCKIFY_LIVE_PREFIX",
        "creates, gets, updates, and deletes a prefixed tag in try/finally",
        "CLOCKIFY_API_KEY",
        "CLOCKIFY_WORKSPACE_ID"
      ]
    },
    {
      "path": "cli/tests/sandbox.test.ts",
      "mustContain": [
        "CLOCKIFY_LIVE_PREFIX",
        "starts, stops, and deletes one project-bound prefixed time entry",
        "creates and archive-deletes a prefixed client/project/task chain",
        "round-trips an entitled prefixed invoice draft",
        "finally"
      ],
      "forbiddenMarkers": [
        "Tests are deliberately read-only",
        "Generic 403",
        "Generic 404"
      ]
    },
    {
      "path": "mcp/tests/sandbox.test.ts",
      "mustContain": [
        "CLOCKIFY_LIVE_PREFIX",
        "guards an entitled business write with bare rejection, dry-run, and one-use execution",
        "finally",
        "cleanupPackage"
      ]
    }
  ],
  "supportingEvidence": [
    {
      "path": "scripts/live/cleanup.test.mjs",
      "mustContain": [
        "cleanupLivePrefixes",
        "continues later cleanup",
        "server clamps below requested page size"
      ]
    },
    {
      "path": "docs/live-tests.md",
      "mustContain": [
        "sacrificial sandbox",
        "sanitized JSON receipt",
        "make perfect-live"
      ]
    },
    {
      "path": "docs/live-safety-contract.json",
      "mustContain": [
        "scripts/run-live-proof.mjs",
        "cleanupLivePrefixes",
        "live_lock_active"
      ]
    },
    {
      "path": "docs/support-runbook.md",
      "mustContain": [
        "cleanup prefix",
        "leftover count",
        "sanitized IDs"
      ]
    },
    {
      "path": "docs/mutation-safety-policy.md",
      "mustContain": [
        "Ambiguous failure recovery",
        "Proof gates"
      ]
    }
  ],
  "requiredMakeTargets": [
    "test-data-lifecycle",
    "live-safety",
    "mock-contract",
    "mutation-safety",
    "support-bundle",
    "perfect-live"
  ],
  "wiring": {
    "makeTarget": "test-data-lifecycle",
    "docsIndex": [
      "test-data-lifecycle-policy.md",
      "test-data-lifecycle-contract.json"
    ],
    "qualityGate": "make test-data-lifecycle",
    "inventoryId": "test-data-lifecycle",
    "auditId": "test-data-lifecycle"
  }
}
