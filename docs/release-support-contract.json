{
  "schemaVersion": 1,
  "purpose": "Release, support, and security documentation contract for the SDK/CLI/MCP platform.",
  "policyDocument": {
    "path": "docs/release-support-policy.md",
    "mustContain": [
      "clockify-sdk-ts-115",
      "@apet97/clockify-cli-115",
      "@apet97/clockify-mcp-115",
      "make perfect-fast",
      "make perfect-full",
      "make pack-smoke",
      "npm publish",
      "SECURITY.md",
      "draft blocker",
      "completed sandbox live proof",
      "immediately before"
    ]
  },
  "securityDocument": {
    "path": "SECURITY.md",
    "mustContain": [
      "clockify-sdk-ts-115",
      "@apet97/clockify-cli-115",
      "@apet97/clockify-mcp-115",
      "GitHub Security Advisories",
      "Do NOT open a public GitHub issue",
      "coordinated-disclosure"
    ],
    "forbiddenRegex": [
      "\\bnpm ls clockify-sdk-ts\\b",
      "\\bclockify-sdk-ts\\b(?!-115)"
    ]
  },
  "packageContract": {
    "path": "docs/package-contract.json",
    "packageNamesMustAppearInPolicy": true,
    "requiredMarkers": [
      "requiredScripts",
      "prepublishOnly"
    ]
  },
  "requiredMakeTargets": [
    "release-support-contract",
    "package-contract",
    "version-policy",
    "changelog-drift",
    "pack-smoke"
  ],
  "docsIndex": [
    "release-support-policy.md",
    "release-support-contract.json"
  ],
  "forbiddenPolicyMarkers": [
    "TODO",
    "TBD"
  ],
  "wiring": {
    "makeTarget": "release-support-contract",
    "qualityGate": "make release-support-contract",
    "inventoryId": "release-support-contract",
    "auditId": "release-support-contract"
  }
}
