{
  "schemaVersion": 1,
  "purpose": "Contract for the operator quickstart receipt: local diagnostics first, mock/live split, first live probes, redaction, and receipt-shaped readiness claims.",
  "contractInvariants": [
    "valid-schema-version",
    "valid-purpose",
    "safe-quickstart-evidence-paths",
    "typed-document-contract",
    "typed-receipt-template-contract",
    "typed-supporting-surfaces",
    "typed-wiring-contract"
  ],
  "document": {
    "path": "docs/quickstart-receipt.md",
    "contains": [
      "Local diagnostics, no network",
      "clockifyDiagnostics",
      "node dist/index.js --json doctor",
      "clockify://mcp/doctor",
      "make mock-clockify",
      "client.health()",
      "clk115 --json status",
      "clockify_status",
      "Quickstart Receipt",
      "Raw secrets printed: no",
      "Workspace ID printed raw: no",
      "Contract-shape rule",
      "Copy-paste safety",
      "Stop conditions",
      "draft blocker",
      "deferred live proof as final readiness"
    ],
    "forbiddenMarkers": [
      "TODO",
      "TBD"
    ]
  },
  "receiptTemplate": {
    "path": "docs/quickstart-receipt.md",
    "requiredFields": [
      "Date: YYYY-MM-DD",
      "Operator:",
      "Surface used: SDK | CLI | MCP",
      "Local diagnostic command/resource:",
      "Local diagnostic status: ready | incomplete | conflict | unsupported",
      "Raw secrets printed: no",
      "Workspace ID printed raw: no",
      "Mock proof used: yes | no",
      "First live probe attempted: yes | no",
      "Live workspace type: sacrificial sandbox | not run",
      "Next action:",
      "Residual risk:"
    ],
    "forbiddenMarkers": [
      "npm publish",
      "CLOCKIFY_API_KEY=real",
      "CLOCKIFY_WORKSPACE_ID=real",
      "PASTE TOKEN",
      "Bearer "
    ]
  },
  "supportingSurfaces": [
    {
      "path": "docs/diagnostics-policy.md",
      "contains": [
        "Diagnostics are no-network by default",
        "local readiness from live proof"
      ]
    },
    {
      "path": "docs/diagnostics-contract.json",
      "contains": [
        "clockifyDiagnostics",
        "clk115 doctor",
        "clockify://mcp/doctor"
      ]
    },
    {
      "path": "docs/operator-onboarding.md",
      "contains": [
        "Mock versus live",
        "final proof"
      ]
    },
    {
      "path": "docs/live-tests.md",
      "contains": [
        "sacrificial Clockify sandbox",
        "Mock/replay proof never replaces live sandbox proof"
      ]
    },
    {
      "path": "docs/product-surface.json",
      "contains": [
        "clockifyDiagnostics",
        "clk115 doctor",
        "clockify://mcp/doctor"
      ]
    }
  ],
  "wiring": {
    "makeTarget": "quickstart-receipt",
    "checker": "scripts/check-quickstart-receipt.mjs",
    "docsIndexDoc": "quickstart-receipt.md",
    "docsIndexContract": "quickstart-receipt-contract.json",
    "qualityGate": "make quickstart-receipt",
    "auditId": "quickstart-receipt"
  }
}
