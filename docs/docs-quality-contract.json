{
  "schemaVersion": 1,
  "purpose": "Evidence-first documentation quality contract for SDK, CLI, MCP, OpenAPI, generated docs, operator docs, and final proof claims.",
  "policyDocument": {
    "path": "docs/docs-quality-policy.md",
    "mustContain": [
      "Evidence-first claims",
      "Generated claim backing",
      "Style rules",
      "Unsupported claim blacklist",
      "Non-coder readability",
      "make docs-quality",
      "node scripts/plan.mjs workflow --workflow first-run-support",
      "safeCommandHints",
      "not proof"
    ],
    "forbiddenMarkers": [
      "TODO",
      "TBD"
    ]
  },
  "keyDocuments": [
    {
      "id": "root-readme",
      "path": "README.md",
      "mustContain": [
        "clockify-sdk-ts-115",
        "@apet97/clockify-cli-115",
        "@apet97/clockify-mcp-115",
        "make perfect-fast",
        "make perfect-full",
        "not affiliated with CAKE.com or Clockify"
      ]
    },
    {
      "id": "sdk-readme",
      "path": "wrapper/README.md",
      "mustContain": [
        "clockify-sdk-ts-115",
        "Observability",
        "Supported runtimes",
        "unofficial, community-built"
      ]
    },
    {
      "id": "sdk-changelog",
      "path": "wrapper/CHANGELOG.md",
      "mustContain": [
        "clockify-sdk-ts-115",
        "create-client",
        "composed-fetch",
        "webhooks"
      ]
    },
    {
      "id": "cli-readme",
      "path": "cli/README.md",
      "mustContain": [
        "@apet97/clockify-cli-115",
        "CLOCKIFY_BASE_URL",
        "generated:cli-commands",
        "Exit codes"
      ]
    },
    {
      "id": "cli-changelog",
      "path": "cli/CHANGELOG.md",
      "mustContain": [
        "@apet97/clockify-cli-115",
        "clockify115",
        "clk115"
      ]
    },
    {
      "id": "mcp-readme",
      "path": "mcp/README.md",
      "mustContain": [
        "@apet97/clockify-mcp-115",
        "structuredContent",
        "generated:mcp-workflow-tools",
        "generated:mcp-domain-tools"
      ]
    },
    {
      "id": "mcp-changelog",
      "path": "mcp/CHANGELOG.md",
      "mustContain": [
        "@apet97/clockify-mcp-115",
        "127-tool surface",
        "workflow tools"
      ]
    },
    {
      "id": "docs-index",
      "path": "docs/README.md",
      "mustContain": [
        "Documentation Index",
        "Operator docs",
        "Generated truth surfaces",
        "Contract checks",
        "Canonical aggregate GitHub-only mutation-proof record, verified"
      ],
      "forbiddenMarkers": [
        "It remains `pending-live-evidence` until"
      ]
    },
    {
      "id": "remote-mutation-receipt",
      "path": "docs/roadmap-1.0-receipts/task-18-remote-mutation.md",
      "mustContain": [
        "GITHUB_TOKEN=\"$(gh auth token)\" node scripts/verify-remote-mutation-proof.mjs",
        "ephemeral process environment",
        "does not print or persist the token"
      ]
    },
    {
      "id": "risk-register-current-blockers",
      "path": "docs/risk-register.md",
      "mustContain": [
        "current final-readiness blocker count is authoritative"
      ],
      "forbiddenMarkers": [
        "four required open blockers"
      ]
    },
    {
      "id": "release-readiness-current-blockers",
      "path": "docs/release-readiness-checklist.md",
      "mustContain": [
        "currently reports zero required open final-readiness blockers"
      ],
      "forbiddenMarkers": [
        "names four required open"
      ]
    },
    {
      "id": "axioms",
      "path": "docs/axioms.md",
      "mustContain": [
        "SDK CLI MCP Axioms",
        "Add metadata before adding prose",
        "Add gates before adding promises",
        "Never make a release/readiness claim without a command that proves it."
      ]
    },
    {
      "id": "axioms-contract",
      "path": "docs/axioms-contract.json",
      "mustContain": [
        "supportingEvidence",
        "truth-source",
        "non-coder-reproducibility"
      ]
    }
  ],
  "supportingEvidence": [
    {
      "path": "docs/unique-claim-inventory-policy.md",
      "mustContain": [
        "canonical claim universe",
        "not completion proof"
      ]
    },
    {
      "path": "scripts/check-docs-drift.mjs",
      "mustContain": [
        "legacy-sdk-package-name",
        "wrapper/CHANGELOG.md",
        "old-mcp-tool-count",
        "placeholder-marker",
        "Documentation drift check passed"
      ]
    },
    {
      "path": "docs/user-docs-policy.md",
      "mustContain": [
        "Required style",
        "make docs-quality",
        "make user-docs"
      ]
    },
    {
      "path": "docs/quality-gates.md",
      "mustContain": [
        "make docs-quality",
        "make docs-drift"
      ]
    }
  ],
  "generatedTruthSurfaces": [
    "docs/product-surface.json",
    "docs/openapi-operations.json",
    "docs/operation-parity.json",
    "docs/cli-commands.json",
    "docs/mcp-tools.json"
  ],
  "productSurfaceClaims": {
    "path": "docs/product-surface.json",
    "requiredWorkflowFields": [
      "surfaceAvailability",
      "proofMode",
      "recovery",
      "intentionalGaps"
    ],
    "surfaceAvailabilityFields": [
      "sdk",
      "cli",
      "tsMcp",
      "goMcp"
    ],
    "emptySurfaceRequiresIntentionalGap": [
      "sdk",
      "cli",
      "tsMcp",
      "goMcp"
    ]
  },
  "scanPaths": [
    "README.md",
    "wrapper/README.md",
    "wrapper/CHANGELOG.md",
    "cli/README.md",
    "cli/CHANGELOG.md",
    "mcp/README.md",
    "mcp/CHANGELOG.md",
    "docs/README.md",
    "docs/user-docs-policy.md",
    "docs/migration-guide.md",
    "docs/release-readiness-checklist.md"
  ],
  "forbiddenUnsupportedClaims": [
    "world[- ]class",
    "battle[- ]tested",
    "production-ready",
    "best[- ]in[- ]class",
    "just works",
    "zero[- ]config"
  ],
  "wiring": {
    "makeTarget": "docs-quality",
    "checker": "scripts/check-docs-quality.mjs",
    "docsIndex": [
      "docs-quality-policy.md",
      "docs-quality-contract.json"
    ],
    "qualityGate": "make docs-quality",
    "inventoryId": "docs-quality",
    "auditId": "docs-quality",
    "uniqueClaimInventory": "unique-claim-inventory"
  }
}
