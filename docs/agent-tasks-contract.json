      "handle-official-openapi-drift.md",
      "handle-live-api-discrepancy.md"
    ],
    "forbiddenMarkers": ["TODO", "TBD"]
  },
  "requiredSections": [
    "## Files to read first",
    "## Files you may edit",
    "## Files you must NOT edit",
    "## Required tests / gates",
    "## Required docs / changelog updates",
    "## Completion checklist"
  ],
  "packets": [
    "docs/agent-tasks/fix-sdk-helper.md",
    "docs/agent-tasks/update-public-export.md",
    "docs/agent-tasks/add-cli-command.md",
    "docs/agent-tasks/add-mcp-tool.md",
    "docs/agent-tasks/handle-official-openapi-drift.md",
    "docs/agent-tasks/handle-live-api-discrepancy.md"
  ],
  "forbiddenMarkers": ["TODO", "TBD"],
  "wiring": {
    "makeTarget": "agent-tasks",
    "checker": "scripts/check-agent-tasks.mjs",
    "qualityGate": "make agent-tasks",
    "inventoryId": "agent-tasks",
    "auditId": "agent-tasks",
    "docsIndex": ["agent-tasks-contract.json"]
  }
}
