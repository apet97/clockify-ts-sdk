{
  "schemaVersion": 1,
  "purpose": "Developer environment and bootstrap contract for local SDK/CLI/MCP/OpenAPI work. Run make help to list all available gates.",
  "policyDocument": {
    "path": "docs/developer-environment-policy.md",
    "mustContain": [
      "Node `>=20`",
      "npm workspaces",
      "root `package.json`",
      "exact `prepublishOnly` command shapes",
      "scripts/generate-sdk-from-openapi.mjs",
      "../GOCLMCP",
      "node scripts/repo-doctor.mjs",
      "make developer-environment"
    ],
    "forbiddenMarkers": [
      "TODO",
      "TBD"
    ]
  },
  "root": {
    "requiredFiles": [
      "package.json",
      "package-lock.json"
    ],
    "workspacesField": [
      "wrapper",
      "cli",
      "mcp"
    ]
  },
  "repoDoctor": {
    "path": "scripts/repo-doctor.mjs",
    "makeTarget": "repo-doctor",
    "mustContain": [
      "network: \"none\"",
      "commandsExecuted: []",
      "envValuesCaptured: false",
      "CLOCKIFY_API_KEY",
      "NPM_TOKEN",
      "GITHUB_TOKEN",
      "../GOCLMCP",
      "scripts/generate-sdk-from-openapi.mjs",
      "requiredScriptValues",
      "wrapper/src",
      "output/ts-sdk"
    ],
    "generatedReport": {
      "network": "none",
      "packageModel": "npm-workspaces",
      "rootPackageJsonAllowed": true,
      "environmentShapeFalseFields": [
        "envValuesCaptured",
        "secretsCaptured",
        "workspaceIdsCaptured"
      ],
      "requiredCheckIds": [
        "node.floor",
        "root.package-json",
        "root.package-lock",
        "root.workspace.wrapper",
        "root.workspace.cli",
        "root.workspace.mcp",
        "wrapper.script.prepublishOnly.command",
        "cli.script.prepublishOnly.command",
        "mcp.script.prepublishOnly.command",
        "codegen.local-generator",
        "codegen.input-openapi",
        "codegen.sync-script",
        "goclmcp.sibling"
      ]
    }
  },
  "packages": [
    {
      "id": "wrapper",
      "manifest": "wrapper/package.json",
      "lockfile": "package-lock.json",
      "requiredScripts": [
        "sync",
        "type-check",
        "build",
        "build:smoke",
        "test",
        "prepublishOnly"
      ],
      "requiredScriptValues": {
        "prepublishOnly": "npm run sync && npm run type-check && npm test && npm run clean && npm run build && npm run build:smoke"
      },
      "engine": ">=20"
    },
    {
      "id": "cli",
      "manifest": "cli/package.json",
      "lockfile": "package-lock.json",
      "requiredScripts": [
        "type-check",
        "build",
        "test",
        "prepublishOnly"
      ],
      "requiredScriptValues": {
        "prepublishOnly": "npm run type-check && npm test && npm run build"
      },
      "engine": ">=20"
    },
    {
      "id": "mcp",
      "manifest": "mcp/package.json",
      "lockfile": "package-lock.json",
      "requiredScripts": [
        "type-check",
        "build",
        "test",
        "verify:live-cleanup",
        "prepublishOnly"
      ],
      "requiredScriptValues": {
        "prepublishOnly": "npm run type-check && npm test && npm run build"
      },
      "engine": ">=20"
    }
  ],
  "localGenerator": {
    "script": "scripts/generate-sdk-from-openapi.mjs",
    "mustContain": [
      "spec/corrected/clockify.corrected.openapi.yaml",
      "output/ts-sdk"
    ]
  },
  "supportingDocs": [
    {
      "path": "AGENTS.md",
      "mustContain": [
        "wired as npm workspaces",
        "../GOCLMCP",
        "scripts/generate-sdk-from-openapi.mjs"
      ]
    },
    {
      "path": "docs/dependency-policy.md",
      "mustContain": [
        "Package runtime floors",
        "Repo-owned local TypeScript generator"
      ]
    },
    {
      "path": "docs/runtime-support.json",
      "mustContain": [
        "\"nodeFloor\": \">=20\"",
        "\"moduleType\": \"module\""
      ]
    },
    {
      "path": "docs/generator-config-contract.json",
      "mustContain": [
        "scripts/generate-sdk-from-openapi.mjs",
        "spec/corrected/clockify.corrected.openapi.yaml"
      ]
    }
  ],
  "wiring": {
    "makeTarget": "developer-environment",
    "checker": "scripts/check-developer-environment.mjs",
    "enterpriseAuditId": "developer-environment"
  }
}
