        "successPattern.test(text)",
        "receipt does not contain any explicit pass/success wording"
      ]
    },
    {
      "path": "scripts/enterprise-goal-status.mjs",
      "mustContain": [
        "finalReceiptHasFinalLiveProofStatus",
        "finalReceiptHasFinalResidualRiskStatus",
        "finalReceiptHasRiskRegisterClear",
        "risk-register-final-status",
