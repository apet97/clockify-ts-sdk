        "manifest.residualRisk.finalRequiredStatus must be listed in manifest.residualRisk.allowedStatuses",
        "manifest.riskRegister.blockingStatuses",
        "manifest.riskRegister.nonBlockingOverrideField",
        "manifest.riskRegister.acceptedNonBlockingStatuses",
        "manifest command section is missing a section name",
        "manifest command section has no commands",
        "manifest.successSectionRequiredPatterns",
        "manifest.successSectionFailureForbiddenPatterns",
        "manifest.budget receipt patterns",
