  ],
  "ambiguousReferencePolicy": {
    "pattern": "make final-proof",
    "allowedLineMarkers": [
      "Alias",
      "alias",
      "back-compatible",
      "ambiguous",
      "final-proof-draft",
      "final-proof-final",
      "\"pattern\":"
    ],
    "scanRoots": [
      "docs",
      "scripts",
      "Makefile"
    ]
  }
