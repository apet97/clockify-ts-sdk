{
  "schemaVersion": 1,
  "purpose": "Cross-surface observability contract for request correlation, telemetry hooks, structured receipts, and safe support bundles.",
  "policyDocument": {
    "path": "docs/observability-policy.md",
    "mustContain": [
      "Observability is a product surface",
      "X-Request-Id",
      "Telemetry levels",
      "prepublish gate metadata",
      "package-lock metadata",
      "Redaction rules",
      "Use `<redacted>`",
      "role placeholders",
      "Do not jump from correlation to raw payload logging",
      "make observability"
    ],
    "forbiddenMarkers": [
      "TODO",
      "TBD"
    ]
  },
  "sdk": [
    {
      "path": "wrapper/composed-fetch.ts",
      "mustContain": [
        "REQUEST_ID_HEADER",
        "USER_AGENT_HEADER",
        "ComposedFetchHooks",
        "beforeRequest",
        "afterResponse",
        "onError",
        "onRetry",
        "getRequestIdFromError"
      ]
    },
    {
      "path": "wrapper/with-response.ts",
      "mustContain": [
        "withResponse",
        "requestId",
        "headers",
        "status",
        "withRawResponse"
      ]
    },
    {
      "path": "wrapper/otel-hooks.ts",
      "mustContain": [
        "otelHooks",
        "http.request.method",
        "http.response.status_code",
        "clockify.http.client.request.duration_ms",
        "peer.service"
      ]
    },
    {
      "path": "wrapper/tests/composed-fetch.test.ts",
      "mustContain": [
        "injects an X-Request-Id UUID per request by default",
        "hook rejections do NOT block the request"
      ]
    },
    {
      "path": "wrapper/tests/with-response.test.ts",
      "mustContain": [
        "returns data + response + headers + requestId + status"
      ]
    }
  ],
  "cli": [
    {
      "path": "cli/src/output.ts",
      "mustContain": [
        "ok: false",
        "code",
        "recoveryForCode",
        "retryableForCode"
      ]
    },
    {
      "path": "cli/tests/exit-contract.test.ts",
      "mustContain": [
        "--json",
        "retryable",
        "recovery"
      ]
    },
    {
      "path": "cli/src/receipt.ts",
      "mustContain": [
        "CliReceipt",
        "ids",
        "changed",
        "warnings",
        "next"
      ]
    }
  ],
  "mcp": [
    {
      "path": "mcp/src/result.ts",
      "mustContain": [
        "structuredContent",
        "changed",
        "warnings",
        "next",
        "recovery",
        "retryableForCode"
      ]
    },
    {
      "path": "mcp/src/output-schema.ts",
      "mustContain": [
        "MCP_RESULT_OUTPUT_SCHEMA",
        "structuredContent",
        "changed",
        "retryAfterSeconds"
      ]
    },
    {
      "path": "mcp/tests/server.test.ts",
      "mustContain": [
        "structured output schema",
        "canonical envelope",
        "structuredContent"
      ]
    }
  ],
  "support": [
    {
      "path": "docs/support-runbook.md",
      "mustContain": [
        "Safe diagnostic bundle",
        "Prepublish gate",
        "Package-lock",
        "requestId",
        "Never include",
        "Proof attempted",
        "Escalation template"
      ]
    },
    {
      "path": "docs/data-handling-policy.md",
      "mustContain": [
        "Workspace identifiers",
        "Allowed placeholders",
        "Prohibited committed evidence",
        "<redacted>"
      ]
    },
    {
      "path": "docs/receipt-examples.md",
      "mustContain": [
        "SDK success receipt",
        "SDK error receipt",
        "CLI success receipt",
        "CLI error receipt",
        "MCP success receipt",
        "MCP recovery receipt",
        "Stable fields",
        "Review rule",
        "requestId",
        "retryable",
        "recovery"
      ],
      "forbiddenMarkers": [
        "sk-",
        "PASTE TOKEN"
      ]
    },
    {
      "path": "docs/receipts-policy.md",
      "mustContain": [
        "X-Request-Id",
        "withResponse",
        "structuredContent",
        "retryable"
      ]
    }
  ],
  "redaction": [
    {
      "path": "docs/observability-policy.md",
      "mustContain": [
        "Redaction rules",
        "Use `<redacted>`",
        "role placeholders",
        "Raw Clockify bodies are a"
      ]
    },
    {
      "path": "docs/data-handling-policy.md",
      "mustContain": [
        "Prohibited committed evidence",
        "Raw package-lock dependency names",
        "<redacted>"
      ]
    },
    {
      "path": "docs/support-bundle-contract.json",
      "mustContain": [
        "redaction",
        "package-lock",
        "readinessContext"
      ]
    }
  ],
  "supportingContracts": [
    {
      "path": "docs/error-codes.json",
      "mustContain": [
        "retryable",
        "recovery"
      ]
    },
    {
      "path": "docs/mcp-contract.json",
      "mustContain": [
        "outputSchema",
        "resources",
        "prompts"
      ]
    },
    {
      "path": "docs/cli-contract.json",
      "mustContain": [
        "exitCodes",
        "globalFlags"
      ]
    }
  ],
  "requiredMakeTargets": [
    "observability",
    "data-handling",
    "support-bundle"
  ],
  "wiring": {
    "makeTarget": "observability",
    "docsIndex": [
      "observability-policy.md",
      "observability-contract.json"
    ],
    "qualityGate": "make observability",
    "inventoryId": "observability",
    "auditId": "observability-contract"
  }
}
