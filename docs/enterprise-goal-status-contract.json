{
  "schemaVersion": 1,
  "purpose": "Contract for the no-network enterprise hardening goal status report. The report is orientation only: it must expose final-proof blockers and commands without running proof gates or collecting secrets.",
  "wiring": {
    "makeTarget": "enterprise-goal-status-contract",
    "checker": "scripts/check-enterprise-goal-status-contract.mjs",
    "enterpriseAuditId": "enterprise-goal-status-contract"
  },
  "statusScript": {
    "path": "scripts/enterprise-goal-status.mjs",
    "formatModes": [
      "markdown",
      "json"
    ],
    "mustContain": [
      "Usage: node scripts/enterprise-goal-status.mjs",
      "--format",
      "markdown",
      "json",
      "JSON.stringify(report, null, 2)",
      "renderMarkdown(report)",
      "network: \"none\"",
      "commandsExecuted: []",
      "envValuesCaptured: false",
      "goalComplete: false",
      "This report is not proof",
      "docs/TEMP_CONTEXT_REMOVE_AFTER_ENTERPRISE_SDK_GOAL.md",
      "docs/final-proof-receipt.md",
      "finalReceiptPresenceStatus",
      "failed-draft marker",
      "NOT COMPLETE:",
      "docs/final-proof-receipt.md exists but contains failed-draft marker",
      "docs/performance-budgets.json",
      "performanceReceiptStatus",
      "readJsonState",
      "parseError",
      "not valid receipt JSON",
      "failedMeasurements",
      "measurement?.ok !== true",
      "expectedPerformanceReceiptCalibrationStatus",
      "embedded calibrationPolicy.status",
      "has passing measurements but embedded calibrationPolicy.status",
      "expectedBudgetSchemaVersion",
      "budgetsSchemaVersion",
      "has passing measurements but budgetsSchemaVersion",
      "expectedBudgetFingerprint",
      "budgetFingerprint",
      "has passing measurements but budgetFingerprint",
      "successful latest receipt",
      "docs/risk-register.json",
      "finalProofCommandOrder",
      "finalProofCommands",
      "make final-proof-preflight",
      "make enterprise-audit",
      "make axioms-contract",
      "axioms-contract-command",
      "make perfect-fast",
      "make performance-receipt",
      "make perfect-full",
      "make perfect-live",
      "finalReceiptHasLiveCleanupProof",
      "finalReceiptHasFinalLiveProofStatus",
      "liveProofSection",
      "liveProofStatus",
      "finalReceiptHasFailedLiveProof",
      "cleanupReceiptMarker",
      "deferredCleanupRequiredMarkers",
      "live-proof-final-status",
      "final live completed status",
      "no-live-objects cleanup marker",
      "failed live proof must be rerun successfully",
      "finalReceiptHasPerformanceProof",
      "finalReceiptHasTightenedBudget",
      "final-receipt-budget-status",
      "Final receipt Performance receipts section must state Budget status: tightened",
      "Set Budget status: tightened in the final receipt Performance receipts section",
      "performanceRequiredRunsPolicyValid",
      "performance-required-runs-policy",
      "calibrationPolicy.requiredSuccessfulRuns must be a positive integer",
      "Set docs/performance-budgets.json calibrationPolicy.requiredSuccessfulRuns to a positive integer",
      "finalReceiptHasFailureMarkers",
      "final-proof-failure-markers",
      "finalReceiptHasRequiredSuccessSectionEvidence",
      "success-section-evidence",
      "finalReceiptHasFinalAuditCommand",
      "final-audit-command-evidence",
      "Final receipt Temporary context cleanup section must include make enterprise-audit-final command evidence",
      "Add make enterprise-audit-final command evidence to the Temporary context cleanup section",
      "successSectionRequiredPatterns",
      "readReceiptSection",
      "blocking",
      "finalReceiptHasResidualRiskDecision",
      "finalReceiptHasFinalResidualRiskStatus",
      "residual-risk-decision",
      "residual-risk-final-status",
      "finalReceiptHasRiskRegisterClear",
      "risk-register-final-status",
      "finalReadinessBlocking",
      "final-blocking open/provisional",
      "noneForbiddenPatterns",
      "Replace failed or deferred live proof",
      "Rerun make perfect-live successfully",
      "live deferral is draft-only",
      "requiredSuccessfulRuns successful performance receipts",
      "Resolve carried residual risks",
      "performance-proof",
      "requiredSuccessfulRuns",
      "Exit status: 0",
      "Result: passed",
      "!tempContextExists",
      "completedCleanupRequiredPrefixes",
      "readFirstFencedBlockAfter",
      "live-cleanup-proof",
      "Sandbox cleanup receipt:",
      "\"total\"\\s*:\\s*0",
      "final-proof-draft",
      "final-proof-receipt-check",
      "final-proof-final",
      "finalBlockingSignalIds",
      "finalBlockingRiskIds",
      "Final blockers",
      "Blocking signals",
      "Blocking risks"
    ],
    "mustNotContain": [
      "node:child_process",
      "spawnSync",
      "execSync",
      "process.env",
      "CLOCKIFY_API_KEY",
      "CLOCKIFY_WORKSPACE_ID",
      "npm ",
      "git ",
      "fern ",
      "docker "
    ]
  },
  "generatedReport": {
    "exactFields": {
      "schemaVersion": 1,
      "network": "none",
      "commandsExecuted": [],
      "envValuesCaptured": false,
      "reportScope": "enterprise-sdk-hardening-goal",
      "goalComplete": false
    },
    "requiredSignalIds": [
      "temporary-context",
      "final-proof-receipt",
      "final-proof-receipt-filled",
      "live-cleanup-proof",
      "live-proof-final-status",
      "performance-baseline",
      "performance-calibration",
      "final-receipt-budget-status",
      "performance-required-runs-policy",
      "performance-proof",
      "final-proof-failure-markers",
      "success-section-evidence",
      "final-audit-command-evidence",
      "residual-risk-decision",
      "residual-risk-final-status",
      "risk-register-final-status",
      "final-proof-preflight-command",
      "enterprise-audit-command",
      "axioms-contract-command",
      "perfect-fast-command",
      "performance-receipt-command",
      "perfect-full-command",
      "perfect-live-command",
      "final-proof-draft-command",
      "final-proof-receipt-check-command",
      "final-proof-acceptance-command"
    ],
    "requiredFinalProofCommandOrder": [
      "preflight",
      "enterpriseAudit",
      "axiomsContract",
      "perfectFast",
      "performanceReceipt",
      "perfectFull",
      "perfectLive",
      "draft",
      "receiptCheck",
      "final"
    ],
    "requiredFinalProofCommands": {
      "preflight": "make final-proof-preflight",
      "enterpriseAudit": "make enterprise-audit",
      "axiomsContract": "make axioms-contract",
      "perfectFast": "make perfect-fast",
      "performanceReceipt": "make performance-receipt",
      "perfectFull": "make perfect-full",
      "perfectLive": "make perfect-live",
      "draft": "LIVE=1 make final-proof-draft or DEFER_LIVE_REASON=\"...\" make final-proof-draft",
      "receiptCheck": "make final-proof-receipt-check",
      "final": "make final-proof-final"
    },
    "warningMustContain": [
      "not proof",
      "must not be used to mark the goal complete"
    ],
    "remainingMustContain": [
      "Run make final-proof-preflight, make enterprise-audit, make axioms-contract, make perfect-fast, make performance-receipt, make perfect-full, make perfect-live",
      "Close final-blocking open/provisional risk-register entries"
    ],
    "requiredFinalBlockingFields": [
      "finalBlockingSignalIds",
      "finalBlockingRiskIds"
    ]
  },
  "makefile": {
    "path": "Makefile",
    "target": "enterprise-goal-status-contract",
    "mustContain": [
      "enterprise-goal-status:",
      "enterprise-goal-status-contract:",
      "node scripts/enterprise-goal-status.mjs",
      "node scripts/check-enterprise-goal-status-contract.mjs"
    ]
  },
  "docs": [
    {
      "path": "docs/quality-gates.md",
      "mustContain": [
        "Print enterprise goal status",
        "Check enterprise goal status contract",
        "make enterprise-goal-status",
        "make enterprise-goal-status-contract"
      ]
    },
    {
      "path": "docs/operator-toolbox.md",
      "mustContain": [
        "make enterprise-goal-status",
        "Preflight",
        "Performance receipt",
        "Live sandbox gate",
        "Draft receipt",
        "Receipt check",
        "Final acceptance"
      ]
    },
    {
      "path": "docs/README.md",
      "mustContain": [
        "enterprise-goal-status-contract.json",
        "Enterprise goal status",
        "Enterprise goal status contract"
      ]
    }
  ],
  "contractInvariants": [
    "valid-schema-version",
    "valid-purpose",
    "safe-enterprise-goal-status-paths",
    "typed-status-script-contract",
    "typed-generated-report-contract",
    "typed-doc-marker-contracts",
    "makefile-audit-wiring"
  ]
}
