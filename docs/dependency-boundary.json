{
  "schemaVersion": 1,
  "purpose": "Dependency boundary contract for SDK, CLI, and MCP packages. Keeps runtime dependencies intentional and prevents generated SDK internals from leaking into sibling packages.",
  "sourceRoots": [
    "cli/src",
    "cli/tests",
    "mcp/src",
    "mcp/tests",
    "wrapper"
  ],
  "ignoredSourcePathSegments": [
    ".stryker-tmp",
    "coverage",
    "dist",
    "node_modules",
    "reports",
    "src"
  ],
  "packages": [
    {
      "id": "wrapper",
      "manifest": "wrapper/package.json",
      "lockfile": "package-lock.json",
      "lockfileVersion": 3,
      "runtimeDependencies": [],
      "peerDependencies": {},
      "requiredDevDependencies": [
        "typescript",
        "vitest",
        "tsx"
      ]
    },
    {
      "id": "cli",
      "manifest": "cli/package.json",
      "lockfile": "package-lock.json",
      "lockfileVersion": 3,
      "runtimeDependencies": [
        "cli-table3",
        "commander",
        "picocolors"
      ],
      "peerDependencies": {
        "clockify-sdk-ts-115": ">=0.11.0 <1"
      },
      "devDependencies": {
        "clockify-sdk-ts-115": "*"
      },
      "requiredDevDependencies": [
        "typescript",
        "vitest",
        "tsx"
      ]
    },
    {
      "id": "mcp",
      "manifest": "mcp/package.json",
      "lockfile": "package-lock.json",
      "lockfileVersion": 3,
      "runtimeDependencies": [
        "@modelcontextprotocol/sdk",
        "zod"
      ],
      "peerDependencies": {
        "clockify-sdk-ts-115": ">=0.11.0 <1"
      },
      "devDependencies": {
        "clockify-sdk-ts-115": "*"
      },
      "requiredDevDependencies": [
        "typescript",
        "vitest",
        "tsx"
      ]
    }
  ],
  "forbiddenRuntimeDependencies": [
    "axios",
    "lodash",
    "moment",
    "request",
    "openai",
    "@anthropic-ai/sdk"
  ],
  "forbiddenDependencyNames": [
    "fern-api",
    "@fern-api/cli",
    "@fern-api/core",
    "@fern-api/cloud",
    "stainless",
    "@stainless-api/sdk",
    "speakeasy",
    "@speakeasy-api/sdk"
  ],
  "forbiddenDependencyManifestPaths": [
    "package.json",
    "wrapper/package.json",
    "cli/package.json",
    "mcp/package.json"
  ],
  "forbiddenImportMarkers": [
    "output/ts-sdk",
    "../wrapper/src",
    "wrapper/src"
  ],
  "wiring": {
    "makeTarget": "dependency-boundary",
    "checker": "scripts/check-dependency-boundary.mjs",
    "enterpriseAuditId": "dependency-boundary"
  }
}
