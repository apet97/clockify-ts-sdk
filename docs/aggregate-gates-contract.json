{
  "schemaVersion": 1,
  "purpose": "Canonical exact-once contract for perfect-fast, perfect-full, and contract-gates across the recursively reached Make DAG and the production verify command plan.",
  "bounds": {
    "maxDepth": 64,
    "maxInvocations": 256,
    "maxTargetVisits": 4096,
    "maxRecipeLines": 4096,
    "maxCommandSegments": 16384,
    "maxCommandTokens": 32768,
    "maxPackageScripts": 4096
