    "npmExecPayloads": "walk npm exec and x payloads recursively through the same bounded command evaluator",
    "npmPrefixOptions": [
      "--prefix",
      "-C"
    ],
    "externalFallbackCondition": "use the committed fallback only when the external directory itself is absent"
  },
