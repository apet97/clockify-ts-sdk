  "makefiles": {
    "allowedDirectories": [
      ".",
      "../GOCLMCP"
    ],
    "fallbacks": {
      "../GOCLMCP": "docs/aggregate-gates-goclmcp.Makefile"
    }
  },
  "reachedCommandPolicy": {
    "makeMarkers": "lexically inventory every standalone Make marker; each executable or dynamically evaluated marker must become a successfully parsed recursive invocation, with inert quoted run-make diagnostics classified explicitly",
