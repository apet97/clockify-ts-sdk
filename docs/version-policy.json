{
  "schemaVersion": 1,
  "purpose": "Package version, identity, and publish-gate contract. Keeps manifests, generated product-surface metadata, changelog anchors, README install examples, and last-resort prepublish gates aligned before any pack or release claim.",
  "productSurfacePath": "docs/product-surface.json",
  "productSurfaceMustMatchManifest": [
    "package",
    "version",
    "prepublishOnly"
  ],
  "expectedPackageCount": 3,
  "requiredPackageIds": [
    "wrapper",
    "cli",
    "mcp"
  ],
  "wiring": {
    "makeTarget": "version-policy",
    "checker": "scripts/check-version-policy.mjs",
    "enterpriseAuditId": "version-policy"
  },
  "packages": [
    {
      "id": "wrapper",
      "manifest": "wrapper/package.json",
      "changelog": "wrapper/CHANGELOG.md",
      "productSurfaceId": "sdk",
      "readme": "wrapper/README.md",
      "installExampleMustContain": "clockify-sdk-ts-115-<version>.tgz",
      "requireCurrentVersionHeading": true
    },
    {
      "id": "cli",
      "manifest": "cli/package.json",
      "changelog": "cli/CHANGELOG.md",
      "productSurfaceId": "cli",
      "requireCurrentVersionHeading": true
    },
    {
      "id": "mcp",
      "manifest": "mcp/package.json",
      "changelog": "mcp/CHANGELOG.md",
      "productSurfaceId": "tsMcp",
      "requireCurrentVersionHeading": true
    }
  ],
  "versionConsistency": {
    "purpose": "Each package identity and package.json version must agree with release-please, generated runtime metadata, declared peer ranges, and any secondary package manifest.",
    "releasePleaseManifest": ".release-please-manifest.json",
    "releasePleaseConfig": "release-please-config.json",
    "packages": [
      {
        "id": "wrapper",
        "manifest": "wrapper/package.json",
        "packageName": "clockify-sdk-ts-115",
        "runtimeVersionFile": "wrapper/generated/version.ts"
      },
      {
        "id": "cli",
        "manifest": "cli/package.json",
        "packageName": "@apet97/clockify-cli-115",
        "runtimeVersionFile": "cli/src/generated/version.ts",
        "peerDependencies": {
          "clockify-sdk-ts-115": ">=0.12.0 <1"
        }
      },
      {
        "id": "mcp",
        "manifest": "mcp/package.json",
        "packageName": "@apet97/clockify-mcp-115",
        "runtimeVersionFile": "mcp/src/generated/version.ts",
        "peerDependencies": {
          "clockify-sdk-ts-115": ">=0.12.0 <1"
        },
        "additionalVersionManifests": [
          "mcp/manifest.json"
        ]
      }
    ]
  }
}
