{
  "schemaVersion": 1,
  "purpose": "Breaking-change review contract for SDK exports, CLI commands, MCP tools, OpenAPI generation, packages, docs, changelogs, migration notes, and proof gates.",
  "breakingChanges": [
    {
      "removed": "allowInsecureBaseUrl",
      "replacement": "allowNonClockifyHttpsHost"
    },
    {
      "removed": "findOrCreateClient",
      "replacement": "ensureClient"
    },
    {
      "removed": "ArchiveThenDeleteResource",
      "replacement": "ArchiveThenDeleteAdapter<TCurrent>"
    }
  ],
  "policyDocument": {
    "path": "docs/breaking-change-review-policy.md",
    "mustContain": [
      "No silent removals",
      "Replacement-first rule",
      "Review record",
      "Forbidden shortcuts",
      "make breaking-change-review"
    ],
    "forbiddenMarkers": [
      "TODO",
      "TBD"
    ]
  },
  "surfaceContracts": [
    {
      "id": "sdk-public-surface",
      "path": "docs/sdk-public-api.json",
      "mustContain": [
        "rootSymbols",
        "subpaths",
        "createClockifyClient",
        "withResponse",
        "ArchiveThenDeleteAdapter"
      ]
    },
    {
      "id": "sdk-breaking-type-contract",
      "path": "wrapper/tests/types/breaking-changes.test-d.ts",
      "mustContain": [
        "removed from the 1.0 root package; use ensureClient",
        "removed from the 1.0 root package; use ArchiveThenDeleteAdapter<TCurrent>",
        "@ts-expect-error: removed in 1.0; use ensureClient",
        "@ts-expect-error: removed in 1.0; use ArchiveThenDeleteAdapter<TCurrent>",
        "allowNonClockifyHttpsHost",
        "IsAny<Parameters<Adapter"
      ]
    },
    {
      "id": "sdk-client-adapter-migration",
      "path": "wrapper/examples/archive-then-delete-client-adapter.ts",
      "mustContain": [
        "ArchiveThenDeleteAdapter<ClockifyApi.Client>",
        "body: clientArchiveReplacementBody(current)",
        "address\", \"currencyCode\", \"email\", \"note"
      ]
    },
    {
      "id": "cli-public-surface",
      "path": "docs/cli-contract.json",
      "mustContain": [
        "commandCount",
        "globalFlags",
        "exitCodes",
        "completionShells"
      ]
    },
    {
      "id": "mcp-public-surface",
      "path": "docs/mcp-contract.json",
      "mustContain": [
        "totalTools",
        "resources",
        "prompts",
        "outputSchema"
      ]
    },
    {
      "id": "package-public-surface",
      "path": "docs/package-contract.json",
      "mustContain": [
        "clockify-sdk-ts-115",
        "@apet97/clockify-cli-115",
        "@apet97/clockify-mcp-115",
        "clockify115-mcp"
      ]
    },
    {
      "id": "version-and-release-surface",
      "path": "docs/version-policy.json",
      "mustContain": [
        "productSurfaceMustMatchManifest",
        "version-policy"
      ]
    },
    {
      "id": "openapi-truth-surface",
      "path": "docs/operation-coverage-contract.json",
      "mustContain": [
        "sdkGenerated",
        "sdkExplicitlyNamed",
        "sdkOperationIdDerived",
        "tsMcpExact",
        "goMcpExact",
        "curated"
      ]
    }
  ],
  "migrationEvidence": [
    {
      "path": "docs/compatibility-policy.md",
      "mustContain": [
        "Do not remove or rename",
        "Add aliases before removals",
        "warnOnce",
        "allowInsecureBaseUrl` → `allowNonClockifyHttpsHost",
        "findOrCreateClient` → `ensureClient",
        "ArchiveThenDeleteResource` →"
      ]
    },
    {
      "path": "docs/migration-guide.md",
      "mustContain": [
        "Breaking change review",
        "Replacement first",
        "Changelog and migration notes",
        "ArchiveThenDeleteAdapter<TCurrent>",
        "archive-then-delete-client-adapter.ts"
      ]
    },
    {
      "path": "docs/release-readiness-checklist.md",
      "mustContain": [
        "Breaking-change review",
        "make breaking-change-review"
      ]
    },
    {
      "path": "docs/acceptance-scenarios.md",
      "mustContain": [
        "Change rule",
        "unit test and no user-facing path"
      ]
    }
  ],
  "changelogs": [
    {
      "path": "wrapper/CHANGELOG.md",
      "mustContain": [
        "## [Unreleased]"
      ]
    },
    {
      "path": "cli/CHANGELOG.md",
      "mustContain": [
        "## [Unreleased]"
      ]
    },
    {
      "path": "mcp/CHANGELOG.md",
      "mustContain": [
        "## [Unreleased]"
      ]
    }
  ],
  "requiredMakeTargets": [
    "breaking-change-review",
    "compatibility-contract",
    "sdk-public-api",
    "cli-contract",
    "mcp-contract",
    "operation-coverage",
    "acceptance-scenarios",
    "changelog-drift",
    "version-policy",
    "pack-smoke"
  ],
  "wiring": {
    "makeTarget": "breaking-change-review",
    "aggregateTarget": "breaking-change-review-run",
    "docsIndex": [
      "breaking-change-review-policy.md",
      "breaking-change-review-contract.json"
    ],
    "qualityGate": "make breaking-change-review",
    "inventoryId": "breaking-change-review",
    "auditId": "breaking-change-review"
  }
}
