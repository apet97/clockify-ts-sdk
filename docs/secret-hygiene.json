{
  "schemaVersion": 1,
  "purpose": "Local secret-hygiene contract for SDK/CLI/MCP hardening. This is a lightweight committed scanner for common token-shaped mistakes; use gitleaks or equivalent for deeper pre-push audits.",
  "wiring": {
    "makeTarget": "secret-hygiene",
    "checker": "scripts/check-secret-hygiene.mjs",
    "enterpriseAuditId": "secret-hygiene"
  },
  "scanExtensions": [
    ".js",
    ".mjs",
    ".cjs",
    ".ts",
    ".tsx",
    ".json",
    ".md",
    ".yml",
    ".yaml",
    ".sh",
    ".toml"
  ],
  "ignoredDirectories": [
    ".git",
    "node_modules",
    "dist",
    "docs/api",
    "output/ts-sdk",
    "wrapper/src",
    "wrapper/dist",
    "cli/dist",
    "mcp/dist"
  ],
  "ignoredFiles": [
    "docs/secret-hygiene.json"
  ],
  "patterns": [
    {
      "id": "openai-key",
      "regex": "\\bsk-[A-Za-z0-9_-]{20,}",
      "message": "OpenAI-style API key"
    },
    {
      "id": "github-token",
      "regex": "\\bgh[pousr]_[A-Za-z0-9_]{20,}",
      "message": "GitHub-style token"
    },
    {
      "id": "npm-token",
      "regex": "\\bnpm_[A-Za-z0-9]{20,}",
      "message": "npm automation token"
    },
    {
      "id": "slack-token",
      "regex": "\\bxox[baprs]-[A-Za-z0-9-]{20,}",
      "message": "Slack-style token"
    },
    {
      "id": "clockify-api-key-assignment",
      "regex": "CLOCKIFY_API_KEY\\s*=\\s*[\"']?(?=[A-Za-z0-9_-]*[0-9])[A-Za-z0-9_-]{16,}",
      "message": "Committed Clockify API key assignment"
    },
    {
      "id": "clockify-addon-token-assignment",
      "regex": "CLOCKIFY_ADDON_TOKEN\\s*=\\s*[\"']?(?=[A-Za-z0-9_-]*[0-9])[A-Za-z0-9_-]{16,}",
      "message": "Committed Clockify addon token assignment"
    },
    {
      "id": "npm-token-env-assignment",
      "regex": "NPM_TOKEN\\s*=\\s*[\"']?(?=[A-Za-z0-9_-]*[0-9])[A-Za-z0-9_-]{16,}",
      "message": "Committed npm token assignment"
    }
  ],
  "requiredDocs": [
    {
      "path": "AGENTS.md",
      "contains": [
        "Never commit",
        "CLOCKIFY_API_KEY"
      ]
    },
    {
      "path": "docs/dependency-policy.md",
      "contains": [
        "Never commit API keys"
      ]
    }
  ]
}
