{
  "name": "@apet97/clockify-cli-115",
  "version": "0.1.1",
  "description": "Unofficial, community-built — not affiliated with CAKE.com or Clockify. Command-line interface for Clockify, built on clockify-sdk-ts-115.",
  "license": "MIT",
  "author": "Aleksandar Petković <petkovic.aleksandar037@gmail.com>",
  "homepage": "https://github.com/apet97/clockify-ts-sdk/tree/main/cli",
  "repository": {
    "type": "git",
    "url": "https://github.com/apet97/clockify-ts-sdk.git",
    "directory": "cli"
  },
  "bugs": {
    "url": "https://github.com/apet97/clockify-ts-sdk/issues"
  },
  "keywords": [
    "clockify",
    "cli",
    "time-tracking",
    "timer"
  ],
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "clockify115": "./dist/index.js",
    "clk115": "./dist/index.js"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "type-check": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prepublishOnly": "npm run type-check && npm test && npm run build"
  },
  "dependencies": {
    "cli-table3": "^0.6.5",
    "commander": "^12.1.0",
    "picocolors": "^1.1.1"
  },
  "peerDependencies": {
    "clockify-sdk-ts-115": ">=0.9.0"
  },
  "devDependencies": {
    "@types/node": "^25",
    "@vitest/coverage-v8": "^4.1.9",
    "clockify-sdk-ts-115": "*",
    "eslint": "^10.5.0",
    "eslint-plugin-import-x": "^4.16.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.59.4",
    "vitest": "^4.1.4"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
