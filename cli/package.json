{
  "name": "@apet97/clockify-cli-115",
  "version": "0.3.3",
  "description": "Unofficial, community-built — not affiliated with CAKE.com or Clockify. Command-line interface for Clockify, built on clockify-sdk-ts-115.",
  "license": "MIT",
  "author": "Aleksandar Petković <petkovic.aleksandar037@gmail.com>",
  "homepage": "https://github.com/apet97/clockify-ts-sdk/tree/main/cli",
  "repository": {
    "type": "git",
    "url": "https://github.com/apet97/clockify-ts-sdk.git",
    "directory": "cli"
  },
  "bugs": {
    "url": "https://github.com/apet97/clockify-ts-sdk/issues"
  },
  "keywords": [
    "clockify",
    "cli",
    "time-tracking",
    "timer"
  ],
  "type": "module",
  "engines": {
    "node": ">=22.13.0"
  },
  "bin": {
    "clockify115": "./dist/index.js",
    "clk115": "./dist/index.js"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "node ../scripts/generate-package-versions.mjs && tsc -p tsconfig.build.json",
    "dev": "node ../scripts/generate-package-versions.mjs && tsx src/index.ts",
    "test": "node ../scripts/generate-package-versions.mjs && vitest run",
    "test:coverage": "node ../scripts/generate-package-versions.mjs && vitest run --coverage",
    "test:watch": "node ../scripts/generate-package-versions.mjs && vitest",
    "mutation": "node ../scripts/generate-package-versions.mjs && npm run build -w clockify-sdk-ts-115 && cd .. && CLOCKIFY_API_KEY='' CLOCKIFY_WORKSPACE_ID='' stryker run cli/stryker.conf.json",
    "type-check": "node ../scripts/generate-package-versions.mjs && tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prepublishOnly": "npm run type-check && npm test && npm run build && node ../scripts/pack-consumer-smoke.mjs --package=cli"
  },
  "dependencies": {
    "cli-table3": "^0.6.5",
    "commander": "^15.0.0",
    "picocolors": "^1.1.1",
    "zod": "^3.25.0"
  },
  "peerDependencies": {
    "clockify-sdk-ts-115": ">=0.12.0 <1"
  },
  "devDependencies": {
    "@types/node": "^22",
    "@vitest/coverage-v8": "^4.1.10",
    "clockify-sdk-ts-115": "*",
    "eslint": "^10.5.0",
    "eslint-plugin-import-x": "^4.17.1",
    "tsx": "^4.19.2",
    "typescript": "^7.0.2",
    "typescript-eslint": "^8.65.0",
    "vitest": "^4.1.10"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
