{
  "name": "@apet97/clockify-mcp-115",
  "version": "0.5.0",
  "description": "Unofficial, community-built — not affiliated with CAKE.com or Clockify. Model Context Protocol server for Clockify. TypeScript sibling to go-clockify (the Go MCP).",
  "license": "MIT",
  "author": "Aleksandar Petković <petkovic.aleksandar037@gmail.com>",
  "homepage": "https://github.com/apet97/clockify-ts-sdk/tree/main/mcp",
  "repository": {
    "type": "git",
    "url": "https://github.com/apet97/clockify-ts-sdk.git",
    "directory": "mcp"
  },
  "bugs": {
    "url": "https://github.com/apet97/clockify-ts-sdk/issues"
  },
  "keywords": [
    "clockify",
    "mcp",
    "model-context-protocol",
    "ai-tools",
    "anthropic",
    "claude"
  ],
  "type": "module",
  "engines": {
    "node": ">=22.13.0"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "default": "./dist/server.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "default": "./dist/client.js"
    }
  },
  "bin": {
    "clockify115-mcp": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "node ../scripts/generate-package-versions.mjs && tsc -p tsconfig.build.json",
    "dev": "tsx src/index.ts",
    "test": "node ../scripts/generate-package-versions.mjs && vitest run",
    "test:coverage": "vitest run --coverage",
    "mutation": "cd .. && CLOCKIFY_API_KEY='' CLOCKIFY_WORKSPACE_ID='' stryker run mcp/stryker.conf.json",
    "test:watch": "vitest",
    "type-check": "node ../scripts/generate-package-versions.mjs && tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "verify:live-cleanup": "npm run build && node scripts/assert-clean-prefixes.mjs",
    "prepublishOnly": "npm run type-check && npm test && npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.25.0"
  },
  "peerDependencies": {
    "clockify-sdk-ts-115": ">=0.11.0 <1"
  },
  "devDependencies": {
    "@types/node": "^22",
    "@vitest/coverage-v8": "^4.1.9",
    "clockify-sdk-ts-115": "*",
    "eslint": "^10.5.0",
    "eslint-plugin-import-x": "^4.16.2",
    "fast-check": "^4.8.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.59.4",
    "vitest": "^4.1.4"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
