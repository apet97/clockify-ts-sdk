# macOS
.DS_Store

# Java SDK reference is a separate clone of clockify/addon-java-sdk
# kept locally for cross-checking only; not part of this repo.
java-sdk-reference/

# Live API probe captures — local evidence only. Promote anything
# canonical into spec/evidence/discrepancies.md and reference the
# probe by relative path; the raw bodies don't ship.
spec/evidence/probes/*.json
spec/evidence/probes/*.hdr
!spec/evidence/probes/README.md

# Build artifacts inside wrapper/ are managed by wrapper/.gitignore;
# this rule pins node_modules at any nesting level just in case.
**/node_modules/
**/*.tsbuildinfo

# Raw Fern generator output. Regenerable from spec/corrected/ via
#   (cd spec/fern && fern generate --group ts --local --force)
# which needs Docker. Contributors who only touch hand-written
# wrapper/cli/mcp surfaces still need Docker now — see AGENTS.md §3
# for the regen chain.
/output/ts-sdk/

# TypeDoc output for the public API reference (Phase 3.3) lands
# at the REPO ROOT under docs/api/. Keep source-authored docs in
# docs/ trackable.
/docs/api/

# IDE / editor noise
.idea/
.vscode/
*.swp
.claude/
